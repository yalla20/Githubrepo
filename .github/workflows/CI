name: Java CI with Docker

on:
  push:
    branches:
      - main

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      # Clone repo (same as Jenkins git step)
      - name: Checkout Code
        uses: actions/checkout@v4

      # Setup Java
      - name: Setup JDK 17
        uses: actions/setup-java@v4
        with:
          distribution: 'temurin'
          java-version: '17'

      # BUILD
      - name: Build
        run: |
          cd 3-java-jenkins-docker-app
          mvn clean package

      # TEST
      - name: Test
        run: |
          cd 3-java-jenkins-docker-app
          mvn test

      # COMPILE & RUN
      - name: Compile and Run
        run: |
          cd 3-java-jenkins-docker-app
          mvn compile
          java -jar target/java-jenkins-docker-1.0-SNAPSHOT.jar

      # Docker Image Creation
      - name: Build Docker Image
        run: |
          cd 3-java-jenkins-docker-app
          docker build -t java-jenkins-docker:latest .

      # Docker Tag
      - name: Tag Docker Image
        run: docker tag java-jenkins-docker:latest yallareddyg/app:v1

      # Docker Login
      - name: Docker Login
        run: echo "${{ secrets.DOCKER_PASS }}" | docker login -u "${{ secrets.DOCKER_USER }}" --password-stdin

      # Docker Push
      - name: Push Docker Image
        run: |
          docker push yallareddyg/app:v1
          echo "Docker image pushed successfully!"
        

